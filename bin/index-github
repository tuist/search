#!/bin/bash
set -euo pipefail

TYPESENSE_API_KEY=$(fnox get TYPESENSE_API_KEY)
CONTAINER=$(ssh root@91.99.179.13 "docker ps --filter label=service=tuist-search --filter label=role=web --format '{{.Names}}' | head -1")
CONTAINER_IP=$(ssh root@91.99.179.13 "docker inspect $CONTAINER --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'")

# Open SSH tunnel to TypeSense
ssh -fN -L 18108:${CONTAINER_IP}:8108 root@91.99.179.13
trap 'pkill -f "ssh -fN -L 18108" 2>/dev/null' EXIT

echo "SSH tunnel open to TypeSense at localhost:18108"

GITHUB_TOKEN=$(fnox get GITHUB_TOKEN 2>/dev/null || echo "")

TYPESENSE_API_KEY="$TYPESENSE_API_KEY" \
TYPESENSE_HOST="http://localhost:18108" \
GITHUB_TOKEN="$GITHUB_TOKEN" \
  python3 "$(dirname "$0")/index-github.py"
