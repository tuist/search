{
  "index_name": "tuist",
  "start_urls": [
    "https://tuist.dev/en/docs",
    "https://tuist.dev/ko/docs",
    "https://tuist.dev/ja/docs",
    "https://tuist.dev/es/docs",
    "https://tuist.dev/ru/docs"
  ],
  "allowed_domains": ["tuist.dev"],
  "stop_urls": [
    "https://tuist.dev/(?![a-z]{2}/docs).*"
  ],
  "selectors": {
    "default": {
      "lvl0": "article h1",
      "lvl1": "article h2",
      "lvl2": "article h3",
      "lvl3": "article h4",
      "lvl4": "article h5",
      "text": "article p, article li, article td"
    }
  },
  "scrape_start_urls": true,
  "strip_chars": " .,;:#",
  "custom_settings": {
    "attributesForFaceting": ["language"]
  }
}
